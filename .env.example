PORT=3000
SITE_URL=http://localhost:3000
NODE_ENV=production

# Необязательно задавать вручную на Railway.
# Если вы подключите Volume, Railway сам передаст путь через RAILWAY_VOLUME_MOUNT_PATH.
# DATA_DIR=/data

# Почта компании (SMTP)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=site@your-domain.ru
SMTP_PASS=your_app_password
MAIL_FROM=site@your-domain.ru
LEADS_TO=info@your-domain.ru

# Telegram уведомления
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=
# Можно указать несколько chat_id через запятую:
# TELEGRAM_CHAT_IDS=123456789,987654321

# Доступ в админ-панель
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change_me_now
COOKIE_SECRET=change_this_long_random_string_123456789
